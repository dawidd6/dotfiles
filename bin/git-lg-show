#!/usr/bin/env bash

set -euo pipefail

git lg --color "$@" |
fzf \
  --ansi \
  --no-sort \
  --reverse \
  --multi \
  --preview 'git show --color {2} | diff-so-fancy' \
  --preview-window 'right:60%:wrap' \
  --header "Tab - select items, Enter - confirm, PgUp/PgDown - scroll preview" \
  --bind 'pgup:preview-up,pgdn:preview-down' |
awk '{print $2}' | tee | wl-copy
