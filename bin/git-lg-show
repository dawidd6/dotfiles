#!/usr/bin/env bash

set -euo pipefail

pager="$(git config --global core.pager)"

# shellcheck disable=2016
git lg --color "$@" | fzf --ansi --no-sort --reverse --preview-window=right:60%:wrap --accept-nth 2 --multi \
    --preview "git show --color \$(echo {} | cut -d' ' -f2) | $pager" \
    --bind "enter:execute(printf '%s\\n' {+} | cut -d' ' -f2 | wl-copy -n)+accept"

