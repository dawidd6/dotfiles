set hidden true
set icons true
set promptfmt "\033[32;1m%d\033[0m\033[1m%f\033[0m"

cmd open ${{
    printf "%s\n" "$fx" | xargs --delimiter='\n' $EDITOR
}}

cmd quit ${{
    if [ "$lf_flag_print_selection" = "true" ]; then
        printf '%s\n' "$fx" > "/proc/$id/fd/1"
    fi
    lf -remote "send $id quit"
}}

map <space> toggle
map <tab> toggle
map d delete
map r rename
map c copy
map x cut
map p paste
map q quit
map <esc> :unselect; clear
