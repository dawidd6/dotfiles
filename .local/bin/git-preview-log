#!/usr/bin/env bash

set -euo pipefail

git log --pretty=format:'%Cred%h%Creset %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset %s %C(yellow)%d%Creset' --color "$@" |
	fzf \
		--ansi \
		--no-sort \
		--reverse \
		--multi \
		--preview 'git show --color {1} | diff-so-fancy' \
		--preview-window 'right:60%:wrap' \
		--bind 'space:execute(git show --color {+1} | diff-so-fancy | less -R)' \
		--bind 'home:first,end:last' \
		--bind 'ctrl-u:preview-up,ctrl-d:preview-down' |
	awk '{print $1}' | tr '\n' ' ' | wl-copy -n
