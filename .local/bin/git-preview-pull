#!/usr/bin/env bash

set -euo pipefail

REMOTE="${1:-origin}"
BRANCH="${2:-"$(git branch --show-current)"}"

git fetch "$REMOTE" "$BRANCH" --quiet

LOCAL="$(git rev-parse HEAD)"
REMOTE_HEAD="$(git rev-parse "$REMOTE/$BRANCH")"

if [[ "$LOCAL" = "$REMOTE_HEAD" ]]; then
    echo "Repository is already up to date."
    exit 0
fi

git log --pretty=format:'%Cred%h%Creset %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset %s %C(yellow)%d%Creset' --stat HEAD.."$REMOTE/$BRANCH"

read -rp "==> Diff? [y/N]: " SHOW_DIFF

if [[ "$SHOW_DIFF" =~ ^[Yy]$ ]]; then
    git diff HEAD.."$REMOTE/$BRANCH"
fi

read -rp "==> Rebase? [y/N]: " PULL

if [[ "$PULL" =~ ^[Yy]$ ]]; then
    git rebase "$REMOTE/$BRANCH" --quiet
fi
