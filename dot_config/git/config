[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset %s %C(yellow)%d%Creset'
    ls = ls-tree -r --name-only HEAD
    unadd = restore --staged

[branch]
    sort = -committerdate

[commit]
    gpgSign = true
    verbose = true

[core]
    pager = delta --diff-so-fancy

[interactive]
    diffFilter = delta --diff-so-fancy --color-only

[merge]
    conflictStyle = zdiff3

[fetch]
    prune = true
    pruneTags = true
    all = true

[format]
    pretty = fuller

[gpg]
    format = ssh

[help]
    autocorrect = prompt

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[tag]
    gpgSign = true
    sort = version:refname

